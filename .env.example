# Backend Java (aeg-core) — desarrollo local
AEG_CORE_API_URL=http://localhost:8080
NEXT_PUBLIC_AEG_CORE_API_URL=http://localhost:8080

# Alias compatibles
API_UPSTREAM_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# Prefijo de rutas API (por defecto /api)
NEXT_PUBLIC_API_PATH_PREFIX=/api

# En Vercel suele activarse el proxy same-origin automáticamente
NEXT_PUBLIC_USE_API_PROXY=false
